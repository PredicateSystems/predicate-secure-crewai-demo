# Zero-Trust Multi-Agent E-commerce Demo
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (choose one)
# =============================================================================

# Option 1: DeepInfra (Recommended for cloud)
# Get your API key at https://deepinfra.com/
DEEPINFRA_API_KEY=

# Option 2: Ollama (Local LLM)
# Run `ollama serve` on your host machine first
# OLLAMA_HOST=http://host.docker.internal:11434

# LLM provider selection: auto, deepinfra, or ollama
# auto = tries deepinfra first, falls back to ollama
LLM_PROVIDER=auto

# =============================================================================
# Demo Configuration
# =============================================================================

# Products to monitor (comma-separated)
PRODUCTS=laptop,monitor,keyboard

# Security mode: strict (fail-closed) or audit (log only)
MODE=strict

# Log level for sidecar: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# Predicate Control Plane (Optional - for cloud-connected mode)
# =============================================================================

# Control Plane URL - if set, enables cloud-connected mode
# Leave empty for local-only mode (default)
# Example: https://api.predicatesystems.ai
CONTROL_PLANE_URL=

# Get your API key at https://studio.predicatesystems.ai
PREDICATE_API_KEY=

# Organization and project IDs (required for cloud-connected mode)
TENANT_ID=
PROJECT_ID=

# Enable policy sync from control plane (true/false)
SYNC_ENABLED=false

# =============================================================================
# Advanced Configuration
# =============================================================================

# Local IdP signing key (for development/air-gapped environments)
# Replace with a secure 32+ character key in production
# LOCAL_IDP_SIGNING_KEY=demo-secret-key-replace-in-production-minimum-32-chars
